# ── navanVoyageAI environment variables ──────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── MongoDB Atlas (shared cluster with EnterpriseDataAgent) ──────────────────
MONGODB_HOST=geminirag.saslfno.mongodb.net
MONGODB_USERNAME=your-mongodb-username
MONGODB_PASSWORD=your-mongodb-password
MONGODB_DB=navanVoyageAI

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Anthropic (used only when judge.use_claude_opus=true) ─────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Amadeus (sandbox) ─────────────────────────────────────────────────────────
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret
AMADEUS_HOSTNAME=test   # test | production

# ── Ports ─────────────────────────────────────────────────────────────────────
VITE_PORT=5210
BACKEND_PORT=8100
MONGODB_PORT=27117
NGINX_PORT=3010
AMADEUS_MCP_PORT=8101

# ── Vite proxy target (frontend dev) ─────────────────────────────────────────
VITE_API_BASE=http://localhost:8100

# ── Demo seed users ───────────────────────────────────────────────────────────
SEED_ADMIN_PASSWORD=admin123
SEED_TRAVELLER_PASSWORD=travel123
