FROM python:3.12-slim

WORKDIR /app

COPY amadeus-mcp/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY amadeus-mcp/ ./amadeus-mcp/
COPY amadeus-mcp/server.py ./server.py

ENV PYTHONPATH=/app

EXPOSE 8101

# Default: HTTP transport (MCP at /mcp, health at /health)
# Pass --stdio to switch to stdio transport
CMD ["python", "server.py"]
